#!/usr/bin/env bash
# Pre-push hook for zulip-hermes-integration
# Runs the same checks as CI before allowing a push.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FAILED=0

run_check() {
    local name="$1"
    shift
    echo -n "→ $name ... "
    if "$@" > /tmp/zulip-hook-$$.log 2>&1; then
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${RED}FAIL${NC}"
        cat /tmp/zulip-hook-$$.log
        FAILED=1
    fi
}

echo "═══════════════════════════════════════"
echo "  Zulip Hermes Pre-Push Checks"
echo "═══════════════════════════════════════"

run_check "Syntax: zulip/adapter.py" python3 -m py_compile zulip/adapter.py
run_check "Syntax: zulip/__init__.py" python3 -m py_compile zulip/__init__.py
run_check "Validate: zulip/plugin.yaml" python3 -c "import yaml; yaml.safe_load(open('zulip/plugin.yaml'))"

# Run pytest only if tests/ directory exists and has test files
if [ -d "tests" ] && [ "$(find tests -name '*.py' -print -quit)" ]; then
    run_check "Tests" python3 -m pytest tests/ -v --tb=short
else
    echo -e "${YELLOW}→ Tests ... SKIP (no tests/ dir or empty)${NC}"
fi

rm -f /tmp/zulip-hook-$$.log

if [ $FAILED -ne 0 ]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════${NC}"
    echo -e "${RED}  Pre-push checks failed.${NC}"
    echo -e "${RED}  Fix errors before pushing.${NC}"
    echo -e "${RED}═══════════════════════════════════════${NC}"
    exit 1
fi

echo ""
echo -e "${GREEN}═══════════════════════════════════════${NC}"
echo -e "${GREEN}  All checks passed. Pushing...${NC}"
echo -e "${GREEN}═══════════════════════════════════════${NC}"
